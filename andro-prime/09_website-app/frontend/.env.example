# ============================================================
# ANDRO PRIME — Environment Variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local — it is gitignored.
# ============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://andro-prime.com

# --- Supabase (EU Frankfurt region — mandatory for UK GDPR) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (copy from Stripe Dashboard → Catalogue → Products → [product] → Pricing)
STRIPE_PRICE_KIT_1=
STRIPE_PRICE_KIT_2=
STRIPE_PRICE_KIT_3=
STRIPE_PRICE_DAILY_STACK=
STRIPE_PRICE_COLLAGEN=
STRIPE_PRICE_COMPLETE_STACK=
STRIPE_PRICE_FOUNDING_MEMBER=

# --- Thriva Solutions (lab partner) ---
THRIVA_API_KEY=
THRIVA_WEBHOOK_SECRET=

# --- Customer.io (email / CRM) ---
CUSTOMERIO_SITE_ID=
CUSTOMERIO_API_KEY=

# --- FirstPromoter (affiliate tracking) ---
FIRSTPROMOTER_API_KEY=
NEXT_PUBLIC_FIRSTPROMOTER_TRACKING_ID=

# --- Upstash QStash (webhook job queue) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Sentry (error monitoring) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Analytics ---
# Plausible: configured via script tag — no server-side key needed for basic setup
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=andro-prime.com
# GA4 server-side events
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
# Meta Conversions API (server-side events only)
META_PIXEL_ID=
META_ACCESS_TOKEN=
