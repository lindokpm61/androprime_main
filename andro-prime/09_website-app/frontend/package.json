{
  "name": "androprime",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "tsx scripts/seed-result.ts",
    "db:sync": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sync-supabase-migrations.ps1",
    "db:start": "npm run db:sync && .\\node_modules\\.bin\\supabase.cmd start --workdir ..",
    "db:status": ".\\node_modules\\.bin\\supabase.cmd status --workdir ..",
    "db:stop": ".\\node_modules\\.bin\\supabase.cmd stop --workdir ..",
    "db:link": ".\\node_modules\\.bin\\supabase.cmd link --workdir ..",
    "db:push": "npm run db:sync && .\\node_modules\\.bin\\supabase.cmd db push --workdir .."
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@upstash/qstash": "^2.10.1",
    "gray-matter": "^4.0.3",
    "next": "15.5.15",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.0.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "postcss": "^8",
    "supabase": "^2.92.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.0.0",
    "typescript": "^5"
  }
}
